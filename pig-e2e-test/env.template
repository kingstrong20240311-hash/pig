# Pig E2E 测试环境变量配置模板
# 使用方法：
# 1. 复制此文件内容
# 2. 根据实际环境修改配置值
# 3. 在命令行中设置环境变量或创建 shell 脚本

# ==================== 必填配置 ====================

# Gateway 服务地址（必填）
export PIG_GATEWAY_URL=http://127.0.0.1:9999

# ==================== 可选配置（有默认值） ====================

# 测试账号
export PIG_TEST_USERNAME=test_user
export PIG_TEST_PASSWORD=test_password

# 管理员 Token（如配置，将跳过登录流程）
# export PIG_ADMIN_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...

# HTTP 连接超时（毫秒）
export PIG_CONNECTION_TIMEOUT=30000

# HTTP 读取超时（毫秒）
export PIG_READ_TIMEOUT=60000

# 轮询最大等待时间（秒）
export PIG_MAX_WAIT_SECONDS=30

# 轮询间隔（毫秒）
export PIG_POLL_INTERVAL_MILLIS=500

# ==================== 不同环境配置示例 ====================

# 本地开发环境示例
# export PIG_GATEWAY_URL=http://localhost:9999

# 测试环境示例
# export PIG_GATEWAY_URL=http://test.pig4cloud.com

# 预发布环境示例
# export PIG_GATEWAY_URL=http://staging.pig4cloud.com

# ==================== 使用示例 ====================

# 方式 1：直接在命令行使用
# source env.template
# mvn -pl pig-e2e-test -Pe2e verify

# 方式 2：创建自定义配置脚本
# cp env.template my-env.sh
# # 编辑 my-env.sh，设置实际配置
# source my-env.sh
# mvn -pl pig-e2e-test -Pe2e verify
